{
  "manifest_version": 3,
  "name": "8591 訂單匯入",
  "version": "1.0",
  "description": "從 8591 賣家後台一鍵匯入訂單到代儲管理系統",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.8591.com.tw/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.8591.com.tw/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon48.png"
  }
}
